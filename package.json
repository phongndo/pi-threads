{
  "name": "pi-threads",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal Pi extension that lets Pi sessions start, poll, message, list, and stop other Pi sessions.",
  "keywords": [
    "agents",
    "pi-extension",
    "pi-package",
    "threads"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "check": "pnpm oxformat:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev:pi": "pi -e .",
    "lint": "oxlint --deny-warnings --tsconfig tsconfig.json src test vitest.config.ts",
    "lint:fix": "pnpm lint --fix",
    "lsp:oxformat": "oxfmt --lsp",
    "lsp:oxlint": "oxlint --lsp",
    "lsp:ts": "typescript-language-server --stdio",
    "oxformat": "oxfmt --write .",
    "oxformat:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typebox": "^1.3.3",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
